{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:semverAllWeekly",
    ":gomod",
    ":noUnscheduledUpdates",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "America/Chicago",
  "platformAutomerge": false,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "security:floor", "renovate:type-security-floor"],
    "vulnerabilityFixStrategy": "lowest",
    "automerge": true
  },
  "osvVulnerabilityAlerts": true,
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update go install tool pins used by GitHub Actions workflows",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+go install \\S+@(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ],
  "packageRules": [
    {
      "description": "Keep the core module pinned to the lowest supported Go patch release",
      "matchManagers": ["gomod"],
      "matchDatasources": ["golang-version"],
      "matchDepTypes": ["golang"],
      "matchDepNames": ["go"],
      "matchFileNames": ["go.mod"],
      "allowedVersions": "/^{{major}}\\.{{minor}}\\.0$/"
    },
    {
      "description": "Ignore local shared .e2e modules resolved via replace directives",
      "matchManagers": ["gomod"],
      "matchFileNames": [".e2e/**"],
      "matchPackageNames": ["github.com/pjscruggs/slogcp-e2e-internal/**"],
      "enabled": false
    },
    {
      "description": "Ignore local slogcp module requirements in .e2e modules resolved via replace directives",
      "matchManagers": ["gomod"],
      "matchFileNames": [".e2e/**"],
      "matchPackageNames": ["github.com/pjscruggs/slogcp"],
      "enabled": false
    },
    {
      "description": "1. CI-only dependency updates run earlier and stay under .github without touching go.mod/go.sum",
      "matchManagers": ["github-actions", "custom.regex"],
      "matchFileNames": [".github/**"],
      "groupName": "daily ci-only deps",
      "labels": ["renovate:type1"],
      "schedule": ["* 2 * * *"],
      "prPriority": 20
    },
    {
      "description": "2. Everything else runs later and requires local validation before cloud E2E",
      "matchManagers": ["gomod"],
      "groupName": "daily full-validation deps",
      "labels": ["renovate:type2"],
      "schedule": ["* 4 * * *"],
      "prPriority": 10
    },
    {
      "description": "Normal root Go module dependency updates require maintainer approval from the Dependency Dashboard",
      "matchManagers": ["gomod"],
      "matchFileNames": ["go.mod"],
      "dependencyDashboardApproval": true,
      "automerge": false,
      "groupName": "root dependency floor candidates",
      "labels": ["dependency-scope:root"],
      "prPriority": 0
    },
    {
      "description": "Security floor updates must not wait for normal root Dependency Dashboard approval",
      "matchManagers": ["gomod"],
      "matchFileNames": ["go.mod"],
      "matchJsonata": ["$exists(vulnerabilityFixVersion)"],
      "dependencyDashboardApproval": false,
      "automerge": true,
      "automergeType": "pr",
      "labels": ["security", "security:floor", "renovate:type-security-floor"]
    },
    {
      "description": "Keep the root go.mod toolchain directive on the latest released Go toolchain without E2E or release",
      "matchManagers": ["gomod"],
      "matchDatasources": ["golang-version"],
      "matchDepTypes": ["toolchain"],
      "matchDepNames": ["go"],
      "matchFileNames": ["go.mod"],
      "dependencyDashboardApproval": false,
      "automerge": true,
      "automergeType": "pr",
      "groupName": "root go toolchain",
      "labels": ["renovate:toolchain", "dependency-scope:toolchain"],
      "prPriority": 15
    },
    {
      "description": "Keep checked-in example module go directives on the latest released Go version",
      "matchManagers": ["gomod"],
      "matchDatasources": ["golang-version"],
      "matchDepTypes": ["golang"],
      "matchDepNames": ["go"],
      "matchFileNames": [".examples/**/go.mod"],
      "rangeStrategy": "bump",
      "dependencyDashboardApproval": false,
      "automerge": true,
      "automergeType": "pr",
      "groupName": "examples go directives",
      "labels": ["renovate:examples", "dependency-scope:examples", "renovate:go-version"],
      "prPriority": 6
    },
    {
      "description": "Routine latest-compatible updates for checked-in example modules",
      "matchManagers": ["gomod"],
      "matchFileNames": [".examples/**"],
      "groupName": "examples module dependencies",
      "labels": ["renovate:examples", "dependency-scope:examples"],
      "schedule": ["* 4 * * *"],
      "prPriority": 5
    },
    {
      "description": "Do not update the local unpublished slogcp requirement used by examples",
      "matchManagers": ["gomod"],
      "matchFileNames": [".examples/**"],
      "matchPackageNames": ["github.com/pjscruggs/slogcp"],
      "enabled": false
    }
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 10
}
