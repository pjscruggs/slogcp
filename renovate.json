{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:semverAllWeekly",
    ":gomod",
    ":noUnscheduledUpdates",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "America/Chicago",
  "platformAutomerge": false,
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update go install tool pins used by GitHub Actions workflows",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+go install \\S+@(?<currentValue>\\S+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ],
  "packageRules": [
    {
      "description": "Keep go directive current",
      "matchDatasources": ["golang-version"],
      "rangeStrategy": "bump"
    },
    {
      "description": "Keep the core module pinned to the lowest supported Go patch release",
      "matchDatasources": ["golang-version"],
      "matchFileNames": ["go.mod"],
      "allowedVersions": "/^{{major}}\\.{{minor}}\\.0$/"
    },
    {
      "description": "Ignore local shared .e2e modules resolved via replace directives",
      "matchManagers": ["gomod"],
      "matchFileNames": [".e2e/**"],
      "matchPackageNames": ["github.com/pjscruggs/slogcp-e2e-internal/**"],
      "enabled": false
    },
    {
      "description": "Ignore local slogcp module requirements in .e2e modules resolved via replace directives",
      "matchManagers": ["gomod"],
      "matchFileNames": [".e2e/**"],
      "matchPackageNames": ["github.com/pjscruggs/slogcp"],
      "enabled": false
    },
    {
      "description": "1. CI-only dependency updates run earlier and stay under .github without touching go.mod/go.sum",
      "matchManagers": ["github-actions", "custom.regex"],
      "matchFileNames": [".github/**"],
      "groupName": "daily ci-only deps",
      "labels": ["renovate:type1"],
      "schedule": ["* 2 * * *"],
      "prPriority": 20
    },
    {
      "description": "2. Everything else runs later and requires local validation before cloud E2E",
      "matchManagers": ["gomod"],
      "groupName": "daily full-validation deps",
      "labels": ["renovate:type2"],
      "schedule": ["* 4 * * *"],
      "prPriority": 10
    }
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 10
}
